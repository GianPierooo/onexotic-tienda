# OnExotic — Tienda web · Contrato de variables de entorno.
# Copia este archivo a .env.local y completa los valores. Las que llevan
# NEXT_PUBLIC_ quedan expuestas en el cliente; el resto solo en el servidor.

# ── Supabase ────────────────────────────────────────────────────────────
# Proyecto exclusivo de la tienda. El project ref oficial es
# jmxiwzotiridrjkdqulh; la app interna de OnExotic vive en OTRO proyecto.
NEXT_PUBLIC_SUPABASE_URL=https://jmxiwzotiridrjkdqulh.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── URL base del sitio ──────────────────────────────────────────────────
# Se usa en metadata, robots, sitemap y JSON-LD del producto.
# En PRODUCCIÓN (Vercel) déjala como https://onexotic.shop.
# En LOCAL puedes sobreescribirla con http://localhost:3000.
NEXT_PUBLIC_SITE_URL=https://onexotic.shop

# ── WhatsApp Business ───────────────────────────────────────────────────
# PHONE: solo dígitos, formato wa.me (sin + ni espacios)
# LABEL: texto legible mostrado al cliente
NEXT_PUBLIC_WHATSAPP_PHONE=51906517394
NEXT_PUBLIC_WHATSAPP_LABEL=+51 906 517 394

# ── Envíos ──────────────────────────────────────────────────────────────
# Todos los montos en soles (PEN). THRESHOLD es el umbral para envío gratis
# (no aplica a envío internacional).
NEXT_PUBLIC_FREE_SHIPPING_THRESHOLD=250
NEXT_PUBLIC_SHIPPING_DEFAULT=15
NEXT_PUBLIC_SHIPPING_LIMA=15
NEXT_PUBLIC_SHIPPING_PROVINCIA=25
NEXT_PUBLIC_SHIPPING_INTL=120

# ── Pagos online (ver docs/pagos-online.md) ─────────────────────────────
# Interruptor MAESTRO. Apagado por defecto: con 'false' (o ausente) NO se
# muestra ningún pago online y el checkout funciona solo con WhatsApp.
NEXT_PUBLIC_PAGOS_ONLINE=false
# Flags por proveedor (se encienden de a uno cuando lleguen sus llaves).
NEXT_PUBLIC_PAGOS_CULQI=false
NEXT_PUBLIC_PAGOS_PAYPAL=false

# Culqi — tarjetas (Perú/internacional) + Yape/Plin. Cobra en PEN.
#   pk_* (pública, va al navegador):
NEXT_PUBLIC_CULQI_PUBLIC_KEY=
#   sk_* (secreta, SOLO servidor):
CULQI_SECRET_KEY=
CULQI_API_BASE=https://api.culqi.com/v2
CULQI_WEBHOOK_SECRET=

# PayPal — pago internacional. Cobra en USD.
#   Client ID (público, va al navegador):
NEXT_PUBLIC_PAYPAL_CLIENT_ID=
#   Client ID + Secret (servidor) y entorno (sandbox|live):
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_ENV=sandbox
PAYPAL_WEBHOOK_ID=

# ── Email transaccional (Resend) ────────────────────────────────────────
# Si RESEND_API_KEY queda vacío, los emails se loguean sin enviarse.
RESEND_API_KEY=
ORDER_EMAIL_FROM=OnExotic <pedidos@onexotic.shop>
